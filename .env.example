NODE_ENV=development
PORT=3000
HOST=127.0.0.1

# For persistent local development with PostgreSQL.
# Example with the included docker-compose service:
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/yt_multi_publi?schema=public
#
# Leave empty to run in in-memory mode (no Prisma/database).
DATABASE_URL=
PUBLIC_APP_URL=http://127.0.0.1:3000

GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/workspace/accounts/callback
GOOGLE_AUTH_REDIRECT_URI=http://127.0.0.1:3000/login/callback
INSTAGRAM_CLIENT_ID=replace-me
INSTAGRAM_CLIENT_SECRET=replace-me
INSTAGRAM_REDIRECT_URI=http://127.0.0.1:3000/workspace/accounts/callback?provider=instagram
TIKTOK_CLIENT_KEY=replace-me
TIKTOK_CLIENT_SECRET=replace-me
TIKTOK_REDIRECT_URI=http://127.0.0.1:3000/workspace/accounts/callback?provider=tiktok

# Must resolve to exactly 32 bytes.
OAUTH_TOKEN_KEY=12345678901234567890123456789012

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=plain:admin123
