NODE_ENV=development
PORT=3000
HOST=127.0.0.1

# For persistent local development with PostgreSQL.
# Example with the included docker-compose service:
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/yt_multi_publi?schema=public
#
# Leave empty to run in in-memory mode (no Prisma/database).
DATABASE_URL=
PUBLIC_APP_URL=http://127.0.0.1:3000
GOOGLE_SITE_VERIFICATION=

GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/workspace/accounts/callback
GOOGLE_AUTH_REDIRECT_URI=http://127.0.0.1:3000/login/callback
TIKTOK_CLIENT_KEY=replace-me
TIKTOK_CLIENT_SECRET=replace-me
TIKTOK_REDIRECT_URI=http://127.0.0.1:3000/workspace/accounts/callback?provider=tiktok
INSTAGRAM_CLIENT_ID=replace-me
INSTAGRAM_CLIENT_SECRET=replace-me
INSTAGRAM_REDIRECT_URI=http://127.0.0.1:3000/workspace/accounts/callback?provider=instagram

# TikTok sandbox / manual E2E verification.
# See docs/TIKTOK_INTEGRATION.md for setup instructions.
TIKTOK_SANDBOX=false
RUN_TIKTOK_SANDBOX_E2E=false
TIKTOK_SANDBOX_CLIENT_KEY=replace-me
TIKTOK_SANDBOX_CLIENT_SECRET=replace-me
TIKTOK_SANDBOX_REDIRECT_URI=http://127.0.0.1:3000/workspace/accounts/callback?provider=tiktok
TIKTOK_SANDBOX_AUTH_CODE=
TIKTOK_SANDBOX_CODE_VERIFIER=
TIKTOK_SANDBOX_ACCESS_TOKEN=
TIKTOK_SANDBOX_REFRESH_TOKEN=
TIKTOK_SANDBOX_PUBLIC_VIDEO_URL=https://example.com/sandbox-video.mp4

# Instagram sandbox / manual E2E verification.
# See docs/INSTAGRAM_INTEGRATION.md for setup instructions.
RUN_INSTAGRAM_SANDBOX_E2E=false
INSTAGRAM_SANDBOX_CLIENT_ID=replace-me
INSTAGRAM_SANDBOX_CLIENT_SECRET=replace-me
INSTAGRAM_SANDBOX_REDIRECT_URI=http://127.0.0.1:3000/workspace/accounts/callback?provider=instagram
INSTAGRAM_SANDBOX_AUTH_CODE=
INSTAGRAM_SANDBOX_CODE_VERIFIER=
INSTAGRAM_SANDBOX_ACCESS_TOKEN=
INSTAGRAM_SANDBOX_REFRESH_TOKEN=
INSTAGRAM_SANDBOX_BUSINESS_ACCOUNT_ID=
INSTAGRAM_SANDBOX_PUBLIC_VIDEO_URL=https://example.com/sandbox-reel.mp4

# Must resolve to exactly 32 bytes.
OAUTH_TOKEN_KEY=12345678901234567890123456789012

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=plain:admin123

# Payment / checkout (used by PaymentService).
# Where the user is redirected after completing or cancelling a checkout.
# Provider defaults to a mock adapter if no real provider is wired.
PAYMENT_SUCCESS_URL=http://127.0.0.1:3000/workspace/planos?payment=success
PAYMENT_CANCEL_URL=http://127.0.0.1:3000/workspace/planos?payment=cancel
# Public HTTPS URL where the provider posts webhooks. Required for Mercado Pago.
PAYMENT_WEBHOOK_URL=https://www.plataformmultipublisher.com/api/account/payments/webhook

# Mercado Pago Checkout Pro.
# REQUIRED IN PRODUCTION: MERCADOPAGO_ACCESS_TOKEN must be set to a valid token.
# Use TEST-... for sandbox, APP_USR-... for production.
# If missing in production, app startup will fail with exit code 1.
MERCADOPAGO_ACCESS_TOKEN=
# STRONGLY RECOMMENDED: Webhook signature verification. Without this, webhooks are not verified.
# Verifies x-signature on incoming webhooks from Mercado Pago.
MERCADOPAGO_WEBHOOK_SECRET=
