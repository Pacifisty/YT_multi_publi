generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id                     String   @id @default(cuid())
  email                  String   @unique
  fullName               String?  @map("full_name")
  passwordHash           String?  @map("password_hash")
  googleSubject          String?  @unique @map("google_subject")
  isActive               Boolean  @default(true) @map("is_active")
  planSelectionCompleted Boolean  @default(false) @map("plan_selection_completed")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

model AccountPlan {
  email               String    @id
  plan                String
  tokens              Int
  lastDailyVisitAt    DateTime? @map("last_daily_visit_at")
  lastMonthlyGrantAt  DateTime? @map("last_monthly_grant_at")
  billingStartedAt    DateTime? @map("billing_started_at")
  billingExpiresAt    DateTime? @map("billing_expires_at")
  selectedAt          DateTime? @map("selected_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("account_plans")
}

model ConnectedAccount {
  id              String   @id @default(cuid())
  ownerEmail      String?  @map("owner_email")
  provider        String
  googleSubject   String?  @map("google_subject")
  email           String?
  displayName     String?  @map("display_name")
  accessTokenEnc  String   @map("access_token_enc")
  refreshTokenEnc String?  @map("refresh_token_enc")
  scopes          String[] @default([])
  tokenExpiresAt  DateTime? @map("token_expires_at")
  status          String   @default("connected")
  connectedAt     DateTime @default(now()) @map("connected_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  channels        YouTubeChannel[]

  @@unique([provider, googleSubject, ownerEmail])
  @@index([ownerEmail])
  @@map("connected_accounts")
}

model YouTubeChannel {
  id                 String   @id @default(cuid())
  connectedAccountId String   @map("connected_account_id")
  connectedAccount   ConnectedAccount @relation(fields: [connectedAccountId], references: [id])
  youtubeChannelId   String   @map("youtube_channel_id")
  title              String
  handle             String?
  thumbnailUrl       String?  @map("thumbnail_url")
  isActive           Boolean  @default(true) @map("is_active")
  lastSyncedAt       DateTime @default(now()) @map("last_synced_at")

  campaignTargets    CampaignTarget[]

  @@unique([connectedAccountId, youtubeChannelId])
  @@index([connectedAccountId])
  @@map("youtube_channels")
}

enum MediaAssetType {
  video
  thumbnail
}

model MediaAsset {
  id                String         @id @default(cuid())
  ownerEmail        String?        @map("owner_email")
  assetType         MediaAssetType @map("asset_type")
  originalName      String         @map("original_name")
  storagePath       String         @map("storage_path")
  sizeBytes         Int            @map("size_bytes")
  mimeType          String         @map("mime_type")
  durationSeconds   Int            @default(0) @map("duration_seconds")
  linkedVideoAssetId String?       @map("linked_video_asset_id")
  linkedVideoAsset  MediaAsset?    @relation("MediaAssetThumbnail", fields: [linkedVideoAssetId], references: [id])
  thumbnails        MediaAsset[]   @relation("MediaAssetThumbnail")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  campaigns         Campaign[]
  campaignTargets   CampaignTarget[]
  preset            MediaAssetPreset?
  playlistItems     PlaylistItem[]

  @@index([ownerEmail])
  @@index([linkedVideoAssetId])
  @@map("media_assets")
}

model MediaAssetPreset {
  id              String     @id @default(cuid())
  videoAssetId    String     @unique @map("video_asset_id")
  videoAsset      MediaAsset @relation(fields: [videoAssetId], references: [id], onDelete: Cascade)
  title           String     @default("")
  description     String     @default("")
  tags            String[]   @default([])
  privacy         String     @default("private")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@map("media_asset_presets")
}

model Playlist {
  id          String   @id @default(cuid())
  ownerEmail  String?  @map("owner_email")
  name        String
  folderPath  String   @map("folder_path")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items       PlaylistItem[]
  campaigns   Campaign[]

  @@index([ownerEmail])
  @@map("playlists")
}

model PlaylistItem {
  id           String     @id @default(cuid())
  playlistId   String     @map("playlist_id")
  playlist     Playlist   @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  videoAssetId String     @map("video_asset_id")
  videoAsset   MediaAsset @relation(fields: [videoAssetId], references: [id], onDelete: Cascade)
  position     Int        @default(0)
  usedAt       DateTime?  @map("used_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([playlistId, videoAssetId])
  @@index([playlistId])
  @@map("playlist_items")
}

enum CampaignStatus {
  draft
  ready
  launching
  completed
  failed
}

model Campaign {
  id               String         @id @default(cuid())
  ownerEmail       String?        @map("owner_email")
  title            String
  videoAssetId     String         @map("video_asset_id")
  videoAsset       MediaAsset     @relation(fields: [videoAssetId], references: [id])
  status           CampaignStatus @default(draft)
  scheduledAt      DateTime?      @map("scheduled_at")
  playlistId       String?        @map("playlist_id")
  playlist         Playlist?      @relation(fields: [playlistId], references: [id])
  autoMode         Boolean        @default(false) @map("auto_mode")
  schedulePattern  String?        @map("schedule_pattern")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  targets          CampaignTarget[]

  @@index([ownerEmail])
  @@index([videoAssetId])
  @@index([playlistId])
  @@map("campaigns")
}

enum TargetStatus {
  aguardando
  enviando
  publicado
  erro
}

/// Platform-specific campaign target
/// - YouTube: channelId + playlistId
/// - TikTok: connectedAccountId + privacyLevel + moderation settings
/// - Instagram: connectedAccountId + caption/share-to-feed settings
model CampaignTarget {
  id                   String       @id @default(cuid())
  campaignId           String       @map("campaign_id")
  campaign             Campaign     @relation(fields: [campaignId], references: [id])
  platform             String       @default("youtube")
  destinationId        String       @default("") @map("destination_id")
  destinationLabel     String?      @map("destination_label")
  connectedAccountId   String?      @map("connected_account_id")
  channelId            String?      @map("channel_id")
  channel              YouTubeChannel? @relation(fields: [channelId], references: [id])
  videoTitle           String       @map("video_title")
  videoDescription     String       @map("video_description")
  tags                 String[]     @default([])
  publishAt            DateTime?    @map("publish_at")
  playlistId           String?      @map("playlist_id")
  privacy              String       @default("private")
  thumbnailAssetId     String?      @map("thumbnail_asset_id")
  thumbnailAsset       MediaAsset?  @relation(fields: [thumbnailAssetId], references: [id])
  status               TargetStatus @default(aguardando)
  externalPublishId    String?      @map("external_publish_id")
  youtubeVideoId       String?      @map("youtube_video_id")
  errorMessage         String?      @map("error_message")
  retryCount           Int          @default(0) @map("retry_count")

  // TikTok-specific fields (optional, null for YouTube targets)
  tiktokPrivacyLevel      String?      @map("tiktok_privacy_level")     // PUBLIC_TO_EVERYONE, FOLLOWER_OF_CREATOR, SELF_ONLY
  tiktokDisableComment    Boolean?     @map("tiktok_disable_comment")   // Disable comments
  tiktokDisableDuet       Boolean?     @map("tiktok_disable_duet")      // Disable duets
  tiktokDisableStitch     Boolean?     @map("tiktok_disable_stitch")    // Disable stitches

  // Instagram-specific fields (optional, null for other targets)
  instagramCaption        String?      @map("instagram_caption")
  instagramShareToFeed    Boolean?     @map("instagram_share_to_feed")

  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  publishJobs          PublishJob[]

  @@index([campaignId])
  @@index([channelId])
  @@index([connectedAccountId])
  @@map("campaign_targets")
}

enum PublishJobStatus {
  queued
  processing
  completed
  failed
}

model PublishJob {
  id                 String           @id @default(cuid())
  campaignTargetId   String           @unique @map("campaign_target_id")
  campaignTarget     CampaignTarget   @relation(fields: [campaignTargetId], references: [id])
  status             PublishJobStatus @default(queued)
  attempt            Int              @default(1)
  progressPercent    Int              @default(0) @map("progress_percent")
  youtubeVideoId     String?          @map("youtube_video_id")
  errorMessage       String?          @map("error_message")
  errorClass         String?          @map("error_class")
  startedAt          DateTime?        @map("started_at")
  completedAt        DateTime?        @map("completed_at")
  createdAt          DateTime         @default(now()) @map("created_at")

  @@map("publish_jobs")
}

model AuditEvent {
  id         String   @id @default(cuid())
  eventType  String   @map("event_type")
  actorEmail String   @map("actor_email")
  campaignId String   @map("campaign_id")
  targetId   String?  @map("target_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([campaignId, createdAt])
  @@index([createdAt])
  @@map("audit_events")
}

model WebhookEvent {
  id                String    @id @default(cuid())
  provider          String
  providerEventId   String    @map("provider_event_id")
  externalReference String?   @map("external_reference")
  eventType         String    @map("event_type")
  status            String
  rawPayload        String?   @map("raw_payload")
  processedAt       DateTime? @map("processed_at")
  errorMessage      String?   @map("error_message")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@unique([provider, providerEventId])
  @@index([externalReference])
  @@index([createdAt])
  @@map("webhook_events")
}
